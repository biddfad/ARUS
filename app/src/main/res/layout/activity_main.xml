<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E0E0E0">

    <!-- 1. WADAH PETA TOMTOM (Layar Penuh ke Belakang) -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/map_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="80dp" />

    <!-- 2. HEADER AREA: SEARCH BAR & KATEGORI PINTAS -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="top">

        <!-- SEARCH BAR -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="8dp">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@android:drawable/ic_menu_search"
                    app:tint="#888888"
                    android:layout_marginStart="8dp"/>

                <EditText
                    android:id="@+id/etInputPencarian"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:hint="Cari lokasi tujuan..."
                    android:background="@android:color/transparent"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:inputType="text"
                    android:imeOptions="actionSearch"/>

                <ImageButton
                    android:id="@+id/btnMic"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@android:drawable/ic_btn_speak_now"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="#2196F3"
                    android:layout_marginEnd="4dp"/>

                <ImageButton
                    android:id="@+id/btnCariKetik"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@android:drawable/ic_menu_send"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="#4CAF50"
                    android:layout_marginEnd="4dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- KATEGORI PINTAS (Scroll Horizontal) -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:clipToPadding="false"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnKategoriSPBU"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SPBU"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                    android:layout_marginEnd="8dp"
                    app:cornerRadius="20dp"
                    app:backgroundTint="@color/cat_spbu_bg"
                    android:textColor="@color/cat_spbu"
                    app:icon="@drawable/ic_gas_station"
                    app:iconTint="@color/cat_spbu"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnKategoriRS"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rumah Sakit"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                    android:layout_marginEnd="8dp"
                    app:cornerRadius="20dp"
                    app:backgroundTint="@color/cat_rs_bg"
                    android:textColor="@color/cat_rs"
                    app:icon="@drawable/ic_hospital"
                    app:iconTint="@color/cat_rs"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnKategoriResto"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Restoran"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                    android:layout_marginEnd="8dp"
                    app:cornerRadius="20dp"
                    app:backgroundTint="@color/cat_resto_bg"
                    android:textColor="@color/cat_resto"
                    app:icon="@drawable/ic_restaurant"
                    app:iconTint="@color/cat_resto"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnKategoriParkir"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Parkir"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                    app:cornerRadius="20dp"
                    app:backgroundTint="@color/cat_parkir_bg"
                    android:textColor="@color/cat_parkir"
                    app:icon="@drawable/ic_parking"
                    app:iconTint="@color/cat_parkir"/>
            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>

    <!-- 3. TOMBOL MY LOCATION -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btnMyLocation"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="96dp"
        android:src="@android:drawable/ic_menu_mylocation"
        app:backgroundTint="#FFFFFF"
        app:tint="#4285F4"
        app:elevation="8dp" />

    <!-- 4. BOTTOM SHEET DASHBOARD -->
    <LinearLayout
        android:id="@+id/bottom_sheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bottom_sheet_bg"
        android:padding="16dp"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
        app:behavior_peekHeight="80dp"
        app:behavior_hideable="false"
        android:elevation="8dp">

        <!-- Drag handle -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp"
            android:background="#D0D0D0"/>

        <!-- Area Status/Notifikasi -->
        <TextView
            android:id="@+id/tvHasilRespon"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Asisten Suara siap! Tekan ikon Mic."
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:textAlignment="center"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="© 2026 ARUS App - GPS Navigasi Cerdas"
            android:textSize="12sp"
            android:textColor="#999999"
            android:textAlignment="center"
            android:layout_marginBottom="8dp"/>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>